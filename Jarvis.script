<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>stemA*I — exam-specific STEM revision</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,500&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#f6f7fb;--surface:#ffffff;--surface-2:#f8fafc;--text:#111827;--muted:#667085;--soft:#eef2ff;
  --line:rgba(17,24,39,.09);--blue:#2557f6;--blue-2:#1d4ed8;--ink:#0b1020;--green:#16a34a;--amber:#f59e0b;
  --shadow:0 20px 70px rgba(15,23,42,.08);--radius:24px;--font:'DM Sans',system-ui,sans-serif;--mono:'DM Mono',monospace;
}
*{box-sizing:border-box;margin:0;padding:0}html{scroll-behavior:smooth}body{font-family:var(--font);background:radial-gradient(circle at 12% 0%,#e9efff 0,transparent 32rem),var(--bg);color:var(--text);line-height:1.5}.wrap{max-width:1140px;margin:0 auto;padding:0 24px}.hide{display:none!important}
button,input,select,textarea{font-family:inherit}button{cursor:pointer}.nav{position:sticky;top:0;z-index:30;background:rgba(255,255,255,.78);backdrop-filter:blur(18px);border-bottom:1px solid var(--line)}.nav-inner{height:66px;display:flex;align-items:center;justify-content:space-between}.brand{font-weight:800;font-size:22px;letter-spacing:-.7px}.brand span{color:var(--blue)}.nav-links{display:flex;align-items:center;gap:6px}.nav-links a,.link-btn{border:0;background:transparent;text-decoration:none;color:var(--muted);font-weight:700;font-size:14px;padding:9px 12px;border-radius:999px}.nav-links a:hover,.link-btn:hover{color:var(--blue);background:var(--soft)}.primary{border:0;background:var(--blue);color:#fff;font-weight:800;border-radius:14px;padding:12px 18px;box-shadow:0 12px 24px rgba(37,87,246,.18)}.primary:hover{background:var(--blue-2)}.secondary{border:1px solid var(--line);background:#fff;color:var(--text);font-weight:800;border-radius:14px;padding:12px 18px}.secondary:hover{border-color:rgba(37,87,246,.35);color:var(--blue)}
.hero{padding:76px 0 46px}.hero-grid{display:grid;grid-template-columns:minmax(0,1.05fr) minmax(360px,.95fr);gap:40px;align-items:center}.eyebrow{display:inline-flex;align-items:center;gap:8px;background:#fff;border:1px solid var(--line);padding:7px 13px;border-radius:999px;color:var(--blue);font-size:13px;font-weight:800;box-shadow:0 10px 30px rgba(15,23,42,.04)}.dot{width:7px;height:7px;background:var(--green);border-radius:50%;box-shadow:0 0 0 5px rgba(22,163,74,.12)}h1{font-size:clamp(44px,6vw,72px);line-height:.96;letter-spacing:-3.4px;margin:20px 0 18px}.thin{font-weight:300;font-style:italic}.blue{color:var(--blue)}.lead{font-size:18px;max-width:620px;color:var(--muted);line-height:1.75}.hero-actions{display:flex;gap:12px;margin:30px 0 18px;flex-wrap:wrap}.trust{display:flex;gap:8px;flex-wrap:wrap;color:var(--muted);font-size:13px;font-weight:700}.chip{border:1px solid var(--line);background:rgba(255,255,255,.75);padding:6px 10px;border-radius:999px}.panel{background:#fff;border:1px solid var(--line);border-radius:var(--radius);box-shadow:var(--shadow);overflow:hidden}.mock-top{display:flex;align-items:center;justify-content:space-between;padding:16px 18px;border-bottom:1px solid var(--line);background:linear-gradient(180deg,#fff,#f8fafc)}.traffic{display:flex;gap:6px}.traffic i{width:10px;height:10px;border-radius:50%;background:#d0d5dd}.mock-body{padding:20px}.question-card{border:1px solid var(--line);border-radius:18px;padding:18px;background:var(--surface-2)}.meta{font-family:var(--mono);font-size:11px;color:var(--blue);font-weight:600;margin-bottom:12px}.q{font-size:15px;color:#1f2937;line-height:1.7}.marks{margin-top:14px;display:flex;gap:8px}.mark{height:7px;flex:1;background:#dbeafe;border-radius:999px}.mark:nth-child(-n+4){background:var(--blue)}.tutor{margin-top:14px;background:var(--ink);color:#fff;border-radius:18px;padding:16px}.tutor-row{display:flex;gap:10px;margin-top:11px}.bubble{font-size:13px;line-height:1.55;padding:10px 12px;border-radius:14px;max-width:88%}.bubble.ai{background:#1e293b}.bubble.me{background:var(--blue);margin-left:auto}.mini-title{font-weight:800;font-size:13px;color:#c7d2fe}.mini-sub{font-size:12px;color:#94a3b8;margin-top:2px}
.section{padding:54px 0}.section-head{text-align:center;max-width:700px;margin:0 auto 28px}.label{font-size:12px;font-weight:900;letter-spacing:1.4px;text-transform:uppercase;color:var(--blue);margin-bottom:10px}.section h2{font-size:clamp(30px,4vw,46px);letter-spacing:-1.8px;line-height:1.05}.section p.sub{color:var(--muted);font-size:16px;margin-top:12px;line-height:1.7}.grid3{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}.card{background:#fff;border:1px solid var(--line);border-radius:22px;padding:22px;box-shadow:0 14px 40px rgba(15,23,42,.04)}.icon{width:44px;height:44px;border-radius:14px;background:var(--soft);display:flex;align-items:center;justify-content:center;color:var(--blue);font-weight:900;margin-bottom:16px}.card h3{font-size:18px;letter-spacing:-.4px;margin-bottom:8px}.card p{font-size:14px;color:var(--muted);line-height:1.65}.flow{display:grid;grid-template-columns:1fr 1fr;gap:18px}.steps{display:flex;flex-direction:column;gap:12px}.step{display:flex;gap:14px;background:#fff;border:1px solid var(--line);border-radius:20px;padding:18px}.num{width:34px;height:34px;border-radius:12px;background:var(--ink);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:900;font-size:13px;flex:none}.step h3{font-size:16px;margin-bottom:4px}.step p{font-size:14px;color:var(--muted)}.spec{padding:22px;background:var(--ink);border-radius:22px;color:#fff;box-shadow:var(--shadow)}.spec h3{font-size:20px;letter-spacing:-.5px}.spec-list{margin-top:18px;display:grid;gap:10px}.spec-item{display:flex;align-items:center;justify-content:space-between;background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.09);border-radius:16px;padding:13px 14px}.spec-item span{font-size:13px;color:#cbd5e1}.tick{color:#86efac;font-weight:900}.demo{display:grid;grid-template-columns:minmax(0,1fr) 360px;gap:0}.practice{padding:20px;border-right:1px solid var(--line)}.chat{display:flex;flex-direction:column;min-height:500px}.tabs{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:14px}.tab{border:1px solid var(--line);background:#fff;color:var(--muted);font-weight:800;font-size:12px;padding:8px 12px;border-radius:999px}.tab.on{background:var(--blue);color:#fff;border-color:var(--blue)}.select-row{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px}select{border:1px solid var(--line);border-radius:13px;padding:11px 12px;background:#fff;color:var(--text);font-weight:700}.demo-q{background:var(--surface-2);border:1px solid var(--line);border-radius:20px;padding:18px;min-height:250px}.demo-q h4{font-size:15px;margin-bottom:10px}.demo-q p{font-size:14px;color:#334155;line-height:1.7}textarea{width:100%;min-height:96px;margin-top:14px;border:1px solid var(--line);border-radius:15px;padding:13px;resize:vertical;outline:none}.actions{display:flex;gap:10px;margin-top:12px}.feedback{margin-top:12px;border-radius:16px;padding:13px;font-size:13px;line-height:1.55}.feedback.good{background:#ecfdf3;border:1px solid #bbf7d0}.feedback.warn{background:#fffbeb;border:1px solid #fde68a}.chat-head{padding:18px;border-bottom:1px solid var(--line);display:flex;align-items:center;gap:10px}.avatar{width:38px;height:38px;border-radius:14px;background:var(--blue);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:900}.messages{padding:16px;display:flex;flex-direction:column;gap:10px;overflow:auto;flex:1;background:#fbfdff}.msg{font-size:13px;line-height:1.6;padding:11px 13px;border-radius:16px;max-width:88%;white-space:pre-wrap}.msg.ai{background:#eef2ff;color:#1e293b;border-bottom-left-radius:5px}.msg.user{background:var(--blue);color:#fff;margin-left:auto;border-bottom-right-radius:5px}.chat-input{display:flex;gap:8px;padding:12px;border-top:1px solid var(--line)}.chat-input input{flex:1;border:1px solid var(--line);border-radius:13px;padding:12px;outline:none}.send{width:44px;border:0;background:var(--blue);color:#fff;border-radius:13px;font-weight:900}.banner{display:flex;align-items:flex-start;gap:12px;background:#fff7ed;border:1px solid #fed7aa;color:#7c2d12;border-radius:18px;padding:14px;margin-bottom:14px;font-size:13px;line-height:1.55}.pricing{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}.price{position:relative}.price.featured{border-color:rgba(37,87,246,.35);box-shadow:0 22px 70px rgba(37,87,246,.12)}.price h3{font-size:19px}.amount{font-size:34px;font-weight:900;letter-spacing:-1.4px;margin:12px 0}.amount small{font-size:14px;color:var(--muted);font-weight:700}.features{display:grid;gap:9px;margin:18px 0}.features li{list-style:none;font-size:14px;color:var(--muted)}.features li:before{content:'✓';color:var(--green);font-weight:900;margin-right:8px}.ribbon{position:absolute;top:16px;right:16px;background:var(--soft);color:var(--blue);font-size:11px;font-weight:900;padding:5px 9px;border-radius:999px}.faq{max-width:820px;margin:auto;display:grid;gap:10px}.faq details{background:#fff;border:1px solid var(--line);border-radius:18px;padding:16px}.faq summary{cursor:pointer;font-weight:900}.faq p{color:var(--muted);font-size:14px;line-height:1.7;margin-top:10px}.cta{background:var(--ink);color:#fff;border-radius:30px;padding:42px;text-align:center}.cta p{color:#94a3b8;margin:12px auto 24px;max-width:560px}footer{padding:34px 0;color:var(--muted);font-size:13px}.foot{display:flex;justify-content:space-between;border-top:1px solid var(--line);padding-top:20px;gap:16px;flex-wrap:wrap}
@media(max-width:900px){.hero-grid,.flow,.demo{grid-template-columns:1fr}.grid3,.pricing{grid-template-columns:1fr}.practice{border-right:0;border-bottom:1px solid var(--line)}.nav-links a{display:none}.hero{padding-top:46px}h1{letter-spacing:-2px}.select-row{grid-template-columns:1fr}.chat{min-height:420px}}@media(max-width:560px){.wrap{padding:0 16px}.nav-inner{height:60px}.hero-actions,.actions{flex-direction:column}.primary,.secondary{width:100%}.cta{padding:30px 20px;border-radius:22px}.panel{border-radius:20px}}
</style>
</head>
<body>
<nav class="nav"><div class="wrap nav-inner"><div class="brand">stem<span>A*I</span></div><div class="nav-links"><a href="#features">Features</a><a href="#demo">Demo</a><a href="#pricing">Pricing</a><button class="primary" onclick="scrollToId('demo')">Try demo →</button></div></div></nav>
<header class="hero"><div class="wrap hero-grid"><div><div class="eyebrow"><span class="dot"></span>AI revision built around UK exam specs</div><h1>The smarter way to revise <span class="blue">STEM</span>.</h1><p class="lead">Generate exam-style questions, build mock papers, mark your working, and get a tutor that explains the method without just dumping the answer.</p><div class="hero-actions"><button class="primary" onclick="scrollToId('demo')">Start a practice session →</button><button class="secondary" onclick="scrollToId('features')">See what it does</button></div><div class="trust"><span class="chip">Edexcel</span><span class="chip">AQA</span><span class="chip">OCR</span><span class="chip">GCSE & A-Level</span><span class="chip">Maths · Physics · Chemistry</span></div></div><div class="panel"><div class="mock-top"><strong>Live practice</strong><div class="traffic"><i></i><i></i><i></i></div></div><div class="mock-body"><div class="question-card"><div class="meta">EDEXCEL A-LEVEL · INTEGRATION · 5 MARKS</div><div class="q">Given that <b>f(x)=3x²+2x−1</b>, find ∫f(x)dx and evaluate the definite integral between x=1 and x=3.</div><div class="marks"><span class="mark"></span><span class="mark"></span><span class="mark"></span><span class="mark"></span><span class="mark"></span></div></div><div class="tutor"><div class="mini-title">stemA*I tutor · online</div><div class="mini-sub">Knows the selected topic, board and current question.</div><div class="tutor-row"><div class="bubble ai">Start by integrating each term separately. What do you get for 3x²?</div></div><div class="tutor-row"><div class="bubble me">x³?</div></div><div class="tutor-row"><div class="bubble ai">Exactly. Then integrate 2x and −1, add C, and substitute the upper and lower limits.</div></div></div></div></div></div></header>
<section class="section" id="features"><div class="wrap"><div class="section-head"><div class="label">Product core</div><h2>Not another generic chatbot.</h2><p class="sub">The product promise is simple: every practice session is tied to the subject, exam board, topic and skill the student is actually revising.</p></div><div class="grid3"><div class="card"><div class="icon">Σ</div><h3>Spec-aware questions</h3><p>Pick board, level and topic. Generate targeted questions with marks, difficulty and expected method.</p></div><div class="card"><div class="icon">✓</div><h3>Marking feedback</h3><p>Submit working and get concise examiner-style feedback: what is right, what is missing, and what to fix.</p></div><div class="card"><div class="icon">AI</div><h3>Guided tutor</h3><p>The tutor uses the current question as context and nudges the student through the method instead of handing over the answer.</p></div></div></div></section>
<section class="section"><div class="wrap flow"><div class="steps"><div class="step"><div class="num">1</div><div><h3>Choose the exact course</h3><p>A-Level Maths, GCSE Physics, OCR Chemistry — no vague revision prompts.</p></div></div><div class="step"><div class="num">2</div><div><h3>Practise by topic</h3><p>Target weak areas like integration, vectors, mechanics, bonding or kinetics.</p></div></div><div class="step"><div class="num">3</div><div><h3>Track exam readiness</h3><p>Build a record of attempted questions, weak topics and mock-paper performance.</p></div></div></div><div class="spec"><h3>What makes the real version credible</h3><div class="spec-list"><div class="spec-item"><b>Question generation</b><span class="tick">grounded by spec</span></div><div class="spec-item"><b>Mark schemes</b><span class="tick">rubric checked</span></div><div class="spec-item"><b>Mock papers</b><span class="tick">weighted by topic</span></div><div class="spec-item"><b>Student progress</b><span class="tick">saved securely</span></div></div></div></div></section>
<section class="section" id="demo"><div class="wrap"><div class="section-head"><div class="label">Interactive prototype</div><h2>Try the practice flow.</h2><p class="sub">This front-end demo uses local sample questions. A production version would call your backend, not expose model keys in the browser.</p></div><div class="banner"><strong>Security note:</strong><span>I removed the “paste your Anthropic API key” pattern. For a real launch, model calls should run through a backend API with rate limits, auth and logging.</span></div><div class="panel demo"><div class="practice"><div class="select-row"><select id="board"><option>Edexcel</option><option>AQA</option><option>OCR</option></select><select id="level"><option>A-Level</option><option>GCSE</option></select></div><div class="tabs" id="subjects"></div><div class="tabs" id="topics"></div><button class="primary" onclick="generateQuestion()">Generate question →</button><div class="demo-q" id="questionBox"><h4>Ready when you are.</h4><p>Choose a subject and topic, then generate a question.</p></div></div><div class="chat"><div class="chat-head"><div class="avatar">AI</div><div><strong>stemA*I Tutor</strong><div style="font-size:12px;color:var(--green);font-weight:800">● Online</div></div></div><div class="messages" id="messages"><div class="msg ai">Generate a question and ask me for a hint. I’ll guide you through the method.</div></div><div class="chat-input"><input id="chatInput" placeholder="Ask for a hint..." onkeydown="if(event.key==='Enter')sendTutor()"><button class="send" onclick="sendTutor()">➜</button></div></div></div></div></section>
<section class="section" id="pricing"><div class="wrap"><div class="section-head"><div class="label">Monetisation</div><h2>Simple pricing that fits students.</h2></div><div class="pricing"><div class="card price"><h3>Free</h3><div class="amount">£0</div><ul class="features"><li>Limited daily questions</li><li>Basic tutor hints</li><li>Topic checklist</li></ul><button class="secondary">Start free</button></div><div class="card price featured"><div class="ribbon">Best fit</div><h3>Plus</h3><div class="amount">£6<small>/mo</small></div><ul class="features"><li>Unlimited practice questions</li><li>Full answer marking</li><li>Mock paper generator</li><li>Progress dashboard</li></ul><button class="primary">Upgrade</button></div><div class="card price"><h3>School</h3><div class="amount">Custom</div><ul class="features"><li>Teacher dashboard</li><li>Class-level analytics</li><li>Safeguarded deployment</li></ul><button class="secondary">Contact</button></div></div></div></section>
<section class="section"><div class="wrap"><div class="faq"><details open><summary>Is this using real AI?</summary><p>This standalone demo uses local example logic so it works without API keys. The correct production setup would use a backend API connected to a model provider.</p></details><details><summary>What would need building next?</summary><p>Authentication, database storage, backend question generation, spec-grounded retrieval, payment handling, and a proper admin dashboard.</p></details><details><summary>Can it become a real business?</summary><p>Yes, but only if the questions are genuinely exam-board faithful and the marking is reliable. That is the hard part and the main moat.</p></details></div></div></section>
<section class="section"><div class="wrap"><div class="cta"><h2>Revision should feel specific, not random.</h2><p>stemA*I gives students targeted STEM practice, instant feedback, and a tutor that actually understands the question they are doing.</p><button class="primary" onclick="scrollToId('demo')">Try the demo →</button></div></div></section>
<footer><div class="wrap foot"><div><strong>stemA*I</strong> · AI-powered STEM revision</div><div>Built for GCSE & A-Level · Edexcel · AQA · OCR</div></div></footer>
<script>
const DATA={
 maths:{name:'Maths',topics:{'Integration':{q:'Given f(x)=3x²+2x−1, find ∫f(x)dx and evaluate the definite integral from x=1 to x=3.',hint:'Integrate term by term: 3x² becomes x³, 2x becomes x², and −1 becomes −x. Then use F(3)−F(1).',answer:['x^3','x²','-x','24']},'Differentiation':{q:'Differentiate y=4x³−5x²+7x−2 and find the gradient when x=2.',hint:'Differentiate each power, then substitute x=2 into the derivative.',answer:['12x','10x','7','35']},'Vectors':{q:'A=(2,1,3), B=(5,−1,7). Find vector AB and its magnitude.',hint:'Subtract A from B component-wise, then use Pythagoras in 3D.',answer:['3','-2','4','sqrt29']}}},
 physics:{name:'Physics',topics:{'Mechanics':{q:'A 2 kg object accelerates at 3 m s⁻². Find the resultant force and state the law used.',hint:'Use F=ma. The law is Newton’s second law.',answer:['6','newton']},'Waves':{q:'A wave has frequency 50 Hz and wavelength 0.40 m. Calculate its speed.',hint:'Use v=fλ.',answer:['20']},'Electricity':{q:'A 12 V supply is connected across a 4 Ω resistor. Find the current.',hint:'Use Ohm’s law, V=IR.',answer:['3']}}},
 chemistry:{name:'Chemistry',topics:{'Bonding':{q:'Explain why magnesium oxide has a high melting point.',hint:'Think ionic lattice and strong electrostatic attractions.',answer:['ionic','electrostatic','energy']},'Kinetics':{q:'State two ways to increase the rate of reaction and explain one in terms of particles.',hint:'Temperature, concentration, pressure, surface area or catalyst. Link to collision frequency or activation energy.',answer:['temperature','concentration','collision']},'Energetics':{q:'Define an exothermic reaction and describe the sign of ΔH.',hint:'Energy is transferred to the surroundings, so ΔH is negative.',answer:['surroundings','negative']}}}
};
let subject='maths',topic='Integration',current=null;
function scrollToId(id){document.getElementById(id).scrollIntoView({behavior:'smooth',block:'start'})}
function render(){const s=document.getElementById('subjects'),t=document.getElementById('topics');s.innerHTML='';Object.keys(DATA).forEach(k=>{const b=document.createElement('button');b.className='tab '+(k===subject?'on':'');b.textContent=DATA[k].name;b.onclick=()=>{subject=k;topic=Object.keys(DATA[k].topics)[0];render()};s.appendChild(b)});t.innerHTML='';Object.keys(DATA[subject].topics).forEach(k=>{const b=document.createElement('button');b.className='tab '+(k===topic?'on':'');b.textContent=k;b.onclick=()=>{topic=k;render()};t.appendChild(b)})}
function generateQuestion(){current=DATA[subject].topics[topic];const board=document.getElementById('board').value,level=document.getElementById('level').value;document.getElementById('questionBox').innerHTML=`<div class="meta">${board.toUpperCase()} ${level.toUpperCase()} · ${topic.toUpperCase()} · 5 MARKS</div><h4>${current.q}</h4><textarea id="answer" placeholder="Write your answer or working here..."></textarea><div class="actions"><button class="primary" onclick="markAnswer()">Submit answer</button><button class="secondary" onclick="generateQuestion()">New question</button></div><div id="feedback"></div>`;addMsg('ai',`Generated a ${topic} question. Try it first, then ask me for a hint if needed.`)}
function markAnswer(){const ans=(document.getElementById('answer').value||'').toLowerCase().replace(/\s/g,'');const hits=current.answer.filter(x=>ans.includes(x.toLowerCase().replace(/\s/g,''))).length;const total=current.answer.length;const marks=Math.max(1,Math.round((hits/total)*5));const good=hits>=Math.ceil(total*.65);document.getElementById('feedback').innerHTML=`<div class="feedback ${good?'good':'warn'}"><strong>${good?'Good attempt':'Needs work'} — ${marks}/5</strong><br>${good?'You have the main method. Tighten notation and make sure the final value is clearly stated.':'You are missing at least one key step. Ask the tutor for a hint and focus on the method rather than guessing the final answer.'}</div>`;addMsg('ai',`Marked: ${marks}/5. ${good?'Your method is mostly there.':'There is a method gap — ask me to walk through the next step.'}`)}
function addMsg(type,text){const m=document.getElementById('messages');const d=document.createElement('div');d.className='msg '+type;d.textContent=text;m.appendChild(d);m.scrollTop=m.scrollHeight}
function sendTutor(){const input=document.getElementById('chatInput');const txt=input.value.trim();if(!txt)return;input.value='';addMsg('user',txt);let reply;if(!current){reply='Generate a question first, then I can give a targeted hint.'}else if(/answer|solve|do it/i.test(txt)){reply='I’ll guide rather than dump the answer. First identify the formula or rule needed, then apply it to each term or quantity in the question.'}else{reply=current.hint}setTimeout(()=>addMsg('ai',reply),220)}
render();
</script>
</body>
</html>
